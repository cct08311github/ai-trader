    # Run all tests
    test_basic_target_price_partial_exit()
    print("✓ test_basic_target_price_partial_exit passed")
    
    test_trailing_stop_exit_after_target()
    print("✓ test_trailing_stop_exit_after_target passed")
    
    test_time_decay_exit()
    print("✓ test_time_decay_exit passed")
    
    test_dynamic_parameters_with_market_metrics()
    print("✓ test_dynamic_parameters_with_market_metrics passed")
    
    test_rsi_extreme_exit()
    print("✓ test_rsi_extreme_exit passed")
    
    test_bollinger_band_exit()
    print("✓ test_bollinger_band_exit passed")
    
    test_momentum_decay_exit()
    print("✓ test_momentum_decay_exit passed")
    
    test_drawdown_protection()
    print("✓ test_drawdown_protection passed")
    
    test_integration_with_risk_engine()
    print("✓ test_integration_with_risk_engine passed")
    
    print("\n✅ All tests passed!")
