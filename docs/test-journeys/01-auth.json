      "role": "ADMIN",
      "setup": null,
      "steps": [
        {
          "action": "navigate",
          "url": "/ai-trader/login"
        },
        {
          "action": "clear_storage",
          "keys": [
            "token",
            "auth_token",
            "accessToken"
          ]
        },
        {
          "action": "navigate",
          "url": "/ai-trader/portfolio"
        },
        {
          "action": "wait",
          "selector": "#login-username, #login-password",
          "timeout": 5000
