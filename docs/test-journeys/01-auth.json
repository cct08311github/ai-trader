    {
      "id": "AUTH-10",
      "name": "Show/hide password toggle works",
      "role": "ADMIN",
      "setup": null,
      "steps": [
        {
          "action": "navigate",
          "url": "/ai-trader/login"
        },
        {
          "action": "wait",
          "selector": "#login-password",
          "timeout": 5000
        },
        {
          "action": "fill",
          "selector": "#login-password",
          "value": "openclaw2026"
        },
        {
          "action": "assert",
          "check": "attribute_equals",
          "selector": "#login-password",
          "attribute": "type",
          "value": "password"
        },
        {
          "action": "click",
          "selector": "#login-password ~ button, button[aria-label*='show' i], button[aria-label*='顯示'], button svg[class*='Eye'], button:has(svg[class*='Eye'])"
        },
        {
          "action": "assert",
          "check": "attribute_equals",
          "selector": "#login-password",
          "attribute": "type",
          "value": "text"
        },
        {
          "action": "click",
          "selector": "#login-password ~ button, button[aria-label*='hide' i], button[aria-label*='隱藏'], button svg[class*='EyeOff'], button:has(svg[class*='EyeOff'])"
        },
        {
          "action": "assert",
          "check": "attribute_equals",
          "selector": "#login-password",
          "attribute": "type",
          "value": "password"
        },
        {
          "action": "screenshot",
          "name": "auth-10-show-hide-password-toggle"
        }
      ]
    }
