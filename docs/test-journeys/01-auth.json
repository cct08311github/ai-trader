{
  "journey": "authentication-authorization",
  "version": "1.1.0",
  "description": "Authentication and authorization flows for ai-trader frontend. Covers login, logout, protected routes, token persistence, and edge cases.",
  "baseUrl": "https://mac-mini.tailde842d.ts.net",
  "credentials": {
    "ADMIN": {
      "username": "admin",
      "password": "openclaw2026",
      "role": "ADMIN"
    }
  },
  "setup": {
    "login": {
      "steps": [
        {
          "action": "navigate",
          "url": "/ai-trader/login"
        },
        {
          "action": "fill",
          "selector": "#login-username",
          "value": "{{username}}"
        },
        {
          "action": "fill",
          "selector": "#login-password",
          "value": "{{password}}"
        },
        {
          "action": "click",
          "selector": "text=登入"
        },
        {
          "action": "wait",
          "selector": "nav, [class*='sidebar'], [class*='dashboard']",
          "timeout": 8000
        }
      ]
    }
  },
  "testCases": [
    {
      "id": "AUTH-01",
      "name": "Login page renders correctly",
      "role": "ADMIN",
      "setup": null,
      "steps": [
        {
          "action": "navigate",
          "url": "/ai-trader/login"
        },
        {
          "action": "wait",
          "selector": "form",
          "timeout": 5000
        },
        {
          "action": "assert",
          "check": "element_exists",
          "selector": "#login-username"
        },
        {
          "action": "assert",
          "check": "element_exists",
          "selector": "#login-password"
        },
        {
          "action": "assert",
          "check": "element_visible",
          "selector": "#login-username"
        },
        {
          "action": "assert",
          "check": "element_visible",
          "selector": "#login-password"
        },
        {
          "action": "assert",
          "check": "element_exists",
          "selector": "text=登入"
        },
        {
          "action": "screenshot",
          "name": "auth-01-login-page-renders"
        }
      ]
    },
    {
      "id": "AUTH-02",
