        {
          "action": "assert",
          "check": "any_element_exists",
          "selectors": [
            "[data-testid=twii-index]",
            ".twii-value",
            "text=TWII",
            "text=加權指數",
            "text=TAIEX"
          ]
        },
        {
          "action": "assert",
          "check": "any_element_exists",
          "selectors": [
            "[data-testid=vix-index]",
            ".vix-value",
            "text=VIX"
