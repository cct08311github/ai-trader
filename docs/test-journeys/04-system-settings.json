          "action": "navigate",
          "url": "/ai-trader/system"
        },
        {
          "action": "wait",
          "selector": "main",
          "timeout": 5000
        },
        {
          "action": "assert",
          "check": "url contains /ai-trader/system"
        },
        {
          "action": "assert",
          "check": "text visible: 服務狀態"
        },
        {
          "action": "screenshot",
          "name": "sys-01-system-page-service-status-panel"
        }
