        {
          "action": "assert",
          "check": "url_contains",
          "value": "/ai-trader/analysis"
        },
        {
          "action": "assert",
          "check": "element_visible",
          "selector": "main"
        },
        {
          "action": "screenshot",
          "name": "ana-01-analysis-page-loads"
        }
