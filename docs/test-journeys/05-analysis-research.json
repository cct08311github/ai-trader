        {
          "action": "fill",
          "selector": "[data-testid=rsi-max], input[name=rsi_max]",
          "value": "70"
        },
        {
          "action": "click",
          "selector": "[data-testid=apply-filters], button[type=submit], button[data-action=screen]"
        },
        {
          "action": "wait",
          "selector": "[data-testid=screener-results], .screener-results, table tbody tr",
          "timeout": 8000
